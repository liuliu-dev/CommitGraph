{
  "compilerOptions": {
    "rootDir": "src",
    "declaration": true,
    "outDir": "dist",
    "target": "ES2015",
    "lib": ["DOM", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react",
    "emitDeclarationOnly": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "types": ["node", "jest"],
    "noEmit": false
  },
  "exclude": [
    "node_modules",
    "dist",
    "storybook-static",
    "src/**/**/*.test.ts",
    "src/**/*.stories.ts", 
    "src/stories/**/*",
    "src/**/sampleCommits.ts",
    "rollup.config.js"
  ],
  "include": ["src/**/*"]
}
